{
    "name": "ossp/mop",
    "description": "OSSP MOP application",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "latte/latte": "^3.0",
        "nette/application": "^3.2",
        "nette/bootstrap": "^3.2",
        "nette/database": "^3.2",
        "nette/di": "^3.1",
        "nette/forms": "^3.2",
        "nette/http": "^3.2",
        "nette/mail": "^4.0",
        "nette/routing": "^3.1",
        "nette/security": "^3.2",
        "nette/utils": "^4.0",
        "tracy/tracy": "^2.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "cs": "php-cs-fixer fix",
        "stan": "phpstan analyse"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1"
    }
}
