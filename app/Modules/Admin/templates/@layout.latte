<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{$title} — {/ifset}OSSP MOP Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold" href="{link :Admin:Dashboard:default}">
            OSSP MOP <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem;">Admin</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{link :Admin:Dashboard:default}">Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{link :Admin:User:default}">
                        Users
                        {if isset($pendingBadge) && $pendingBadge > 0}
                            <span class="badge bg-warning text-dark">{$pendingBadge}</span>
                        {/if}
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{link :Admin:UserApproval:default}">Pending Approvals</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        Items
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="{link :Admin:Item:default}">All Items</a></li>
                        <li><a class="dropdown-item" href="{link :Admin:Item:create}">+ Add Item</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="{link :Admin:ItemType:default}">Item Types</a></li>
                        <li><a class="dropdown-item" href="{link :Admin:Location:default}">Locations</a></li>
                    </ul>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{link :Admin:EmailLog:default}">Email Log</a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <span class="navbar-text me-3 small text-light">
                        {$user->getIdentity()?->getData()['first_name']}
                        {$user->getIdentity()?->getData()['last_name']}
                    </span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{link :Front:Homepage:default}">&larr; Back to App</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-warning" href="{link :Front:Auth:logout}">Log Out</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<main class="py-4">
    <div class="container-fluid px-4">

        {foreach $flashes as $flash}
            <div class="alert alert-{$flash->type} alert-dismissible fade show" role="alert">
                {$flash->message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {/foreach}

        {include content}

    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
