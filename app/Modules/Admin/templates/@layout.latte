<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{$title} — {/ifset}OSSP MOP Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/app.css">
</head>
<body class="bg-light">

{* ── Fixed top navbar ────────────────────────────────────────────────── *}
<nav class="navbar navbar-mop fixed-top py-0" style="height:56px;z-index:1030;">
    <div class="container-fluid px-3">

        {* Mobile: sidebar toggle *}
        <button class="btn btn-link text-white d-md-none p-1 me-1 border-0"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#adminSidebar"
                aria-expanded="false"
                aria-label="Toggle sidebar">
            <i class="bi bi-list fs-4"></i>
        </button>

        {* Brand *}
        <a class="navbar-brand d-flex align-items-center gap-2"
           href="{link :Admin:Dashboard:default}">
            <i class="bi bi-shield-check text-accent"></i>
            OSSP MOP
            <span class="badge ms-1 fw-semibold"
                  style="background:var(--mop-accent);font-size:.65rem;letter-spacing:.03em;">
                ADMIN
            </span>
        </a>

        {* Right: user + actions *}
        <div class="d-flex align-items-center gap-2 ms-auto">
            {var $identity = $user->getIdentity()}
            {var $firstName = $identity?->getData()['first_name'] ?? 'Admin'}
            {var $lastName  = $identity?->getData()['last_name'] ?? ''}
            {var $initials  = mb_strtoupper(mb_substr($firstName, 0, 1)) . mb_strtoupper(mb_substr($lastName, 0, 1))}

            <span class="d-none d-md-flex align-items-center gap-2 text-white-50 small">
                <span class="avatar avatar-sm av-{mb_strtolower(mb_substr($firstName, 0, 1))}">{$initials}</span>
                {$firstName} {$lastName}
            </span>

            <a href="{link :Front:Homepage:default}"
               class="btn btn-sm btn-outline-light d-none d-md-inline-flex align-items-center gap-1"
               style="font-size:.8rem;">
                <i class="bi bi-arrow-left"></i> App
            </a>
            <a href="{link :Front:Auth:logout}"
               class="btn btn-sm"
               style="background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.25);font-size:.8rem;">
                <i class="bi bi-box-arrow-right me-1"></i>Logout
            </a>
        </div>
    </div>
</nav>

{* ── Two-column layout: sidebar + content ────────────────────────────── *}
{var $pName = $presenter->getName()}
<div class="d-flex admin-layout" style="margin-top:56px;min-height:calc(100vh - 56px);">

    {* ── Sidebar ───────────────────────────────────────────────────── *}
    <nav class="admin-sidebar collapse d-md-block" id="adminSidebar">

        <div class="sidebar-section">
            <span class="sidebar-section-title">Overview</span>
            <a href="{link :Admin:Dashboard:default}"
               class="nav-link {if $pName === 'Admin:Dashboard'}active{/if}">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
        </div>

        <div class="sidebar-section">
            <span class="sidebar-section-title">Users</span>
            <a href="{link :Admin:User:default}"
               class="nav-link {if $pName === 'Admin:User'}active{/if}">
                <i class="bi bi-people"></i> All Users
            </a>
            <a href="{link :Admin:UserApproval:default}"
               class="nav-link {if $pName === 'Admin:UserApproval'}active{/if}">
                <i class="bi bi-person-check"></i> Approvals
                {if isset($pendingBadge) && $pendingBadge > 0}
                    <span class="badge bg-danger ms-auto" style="font-size:.6rem;">{$pendingBadge}</span>
                {/if}
            </a>
        </div>

        <div class="sidebar-section">
            <span class="sidebar-section-title">Inventory</span>
            <a href="{link :Admin:Item:default}"
               class="nav-link {if $pName === 'Admin:Item'}active{/if}">
                <i class="bi bi-box-seam"></i> Items
            </a>
            <a href="{link :Admin:Item:create}"
               class="nav-link {if $pName === 'Admin:Item' && $presenter->getAction() === 'create'}active{/if}">
                <i class="bi bi-plus-circle"></i> Add Item
            </a>
            <a href="{link :Admin:ItemType:default}"
               class="nav-link {if $pName === 'Admin:ItemType'}active{/if}">
                <i class="bi bi-tag"></i> Item Types
            </a>
            <a href="{link :Admin:Location:default}"
               class="nav-link {if $pName === 'Admin:Location'}active{/if}">
                <i class="bi bi-geo-alt"></i> Locations
            </a>
        </div>

        <div class="sidebar-section">
            <span class="sidebar-section-title">Logs</span>
            <a href="{link :Admin:EmailLog:default}"
               class="nav-link {if $pName === 'Admin:EmailLog'}active{/if}">
                <i class="bi bi-envelope-check"></i> Email Log
            </a>
        </div>

        <div class="sidebar-section mt-2 border-top pt-3">
            <a href="{link :Front:Ticket:default}"
               class="nav-link text-muted">
                <i class="bi bi-ticket-perforated"></i> View Tickets
            </a>
        </div>

    </nav>

    {* ── Main content ──────────────────────────────────────────────── *}
    <div class="admin-content bg-light flex-grow-1">

        {* Flash messages *}
        {foreach $flashes as $flash}
            {var $flashIcon = match($flash->type) {
                'success' => 'bi-check-circle-fill',
                'danger'  => 'bi-x-circle-fill',
                'warning' => 'bi-exclamation-triangle-fill',
                default   => 'bi-info-circle-fill',
            }}
            <div class="alert alert-{$flash->type} alert-dismissible alert-auto-dismiss fade show d-flex align-items-center gap-2 mb-3"
                 role="alert">
                <i class="bi {$flashIcon} flex-shrink-0"></i>
                <span>{$flash->message}</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        {/foreach}

        {include content}

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
{block scripts}{/block}
</body>
</html>
