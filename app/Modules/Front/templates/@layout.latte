<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{$title} — {/ifset}OSSP MOP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="{link :Front:Homepage:default}">OSSP MOP</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{link :Front:Homepage:default}">Home</a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                {if $presenter->getUser()->isLoggedIn()}
                    {var $identity = $presenter->getUser()->getIdentity()}
                    {if $presenter->getUser()->isInRole('admin')}
                        <li class="nav-item">
                            <a class="nav-link" href="{link :Admin:Dashboard:default}">Admin Panel</a>
                        </li>
                    {/if}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            {$identity?->getData()['first_name']} {$identity?->getData()['last_name']}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text small text-muted">{$identity?->getData()['email']}</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{link :Front:Auth:logout}">Log Out</a></li>
                        </ul>
                    </li>
                {else}
                    <li class="nav-item">
                        <a class="nav-link" href="{link :Front:Auth:login}">Log In</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{link :Front:Auth:register}">Register</a>
                    </li>
                {/if}
            </ul>
        </div>
    </div>
</nav>

<main class="py-4">
    {* Flash messages — rendered in the layout so every presenter benefits *}
    <div class="container">
        {foreach $flashes as $flash}
            <div class="alert alert-{$flash->type} alert-dismissible fade show" role="alert">
                {$flash->message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {/foreach}
    </div>

    {include content}
</main>

<footer class="bg-light border-top py-3 mt-auto">
    <div class="container text-center text-muted small">
        &copy; {date('Y')} OSSP MOP
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
