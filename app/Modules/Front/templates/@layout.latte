<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{$title} — {/ifset}OSSP MOP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="{link :Front:Homepage:default}">OSSP MOP</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">

            {* ── Left side: contextual navigation items ─────────────────── *}
            <ul class="navbar-nav me-auto">

                {* All visitors *}
                <li class="nav-item">
                    <a class="nav-link" href="{link :Front:Ticket:default}">Tickets</a>
                </li>

                {if $user->isLoggedIn()}

                    {* Employee, Support, Admin *}
                    {if $roleHelper->isEmployee()}
                        <li class="nav-item">
                            <a class="nav-link" href="{link :Front:Item:default}">Items</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{link :Front:Ticket:create}">Create Ticket</a>
                        </li>
                    {/if}

                    {* Support and Admin *}
                    {if $roleHelper->isSupport()}
                        <li class="nav-item">
                            <a class="nav-link" href="{link :Front:Support:default}">Support Tools</a>
                        </li>
                    {/if}

                    {* Admin only *}
                    {if $roleHelper->isAdmin()}
                        <li class="nav-item">
                            <a class="nav-link" href="{link :Admin:Dashboard:default}">Admin Panel</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{link :Admin:UserApproval:default}">User Management</a>
                        </li>
                    {/if}

                {/if}
            </ul>

            {* ── Right side: notifications + identity / auth ─────────────── *}
            <ul class="navbar-nav ms-auto align-items-center">
                {if $user->isLoggedIn()}

                    {* ── Bell notification dropdown ──────────────────────── *}
                    <li class="nav-item dropdown me-2">
                        <a class="nav-link position-relative px-2"
                           href="#"
                           id="notificationDropdownToggle"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false"
                           aria-label="Notifications">
                            <i class="bi bi-bell fs-5"></i>
                            <span id="notificationBadge"
                                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger
                                         {if ($unreadNotificationCount ?? 0) === 0}d-none{/if}"
                                  style="font-size:.65rem;">
                                {if ($unreadNotificationCount ?? 0) > 99}99+{else}{$unreadNotificationCount ?? 0}{/if}
                            </span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end p-0" style="min-width:320px;max-width:380px;">
                            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                                <span class="fw-semibold small">Notifications</span>
                                <button id="notificationMarkAllBtn"
                                        class="btn btn-link btn-sm p-0 text-decoration-none
                                               {if ($unreadNotificationCount ?? 0) === 0}d-none{/if}"
                                        type="button">
                                    Mark all as read
                                </button>
                            </div>
                            <ul id="notificationDropdownList" class="list-unstyled mb-0" style="max-height:340px;overflow-y:auto;">
                                <li>
                                    <span class="dropdown-item-text text-muted small py-2">Loading…</span>
                                </li>
                            </ul>
                            <div class="border-top text-center py-2">
                                <a class="small text-decoration-none" href="{link :Front:Notifications:default}">
                                    View all notifications
                                </a>
                            </div>
                        </div>
                    </li>

                    {* ── User identity dropdown ───────────────────────────── *}
                    {var $identity = $user->getIdentity()}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            {$identity?->getData()['first_name']} {$identity?->getData()['last_name']}
                            <span class="badge bg-secondary ms-1" style="font-size:.65rem;">
                                {$roleHelper->getRole()}
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <span class="dropdown-item-text small text-muted">
                                    {$identity?->getData()['email']}
                                </span>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="{link :Front:Auth:logout}">Log Out</a></li>
                        </ul>
                    </li>

                {else}
                    <li class="nav-item">
                        <a class="nav-link" href="{link :Front:Auth:login}">Log In</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{link :Front:Auth:register}">Register</a>
                    </li>
                {/if}
            </ul>

        </div>
    </div>
</nav>

<main class="py-4">
    <div class="container">
        {foreach $flashes as $flash}
            <div class="alert alert-{$flash->type} alert-dismissible fade show" role="alert">
                {$flash->message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {/foreach}
    </div>

    {include content}
</main>

<footer class="bg-light border-top py-3 mt-auto">
    <div class="container text-center text-muted small">
        &copy; {date('Y')} OSSP MOP
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{if $user->isLoggedIn()}
    <script src="/js/notifications.js"></script>
{/if}
{block scripts}{/block}
</body>
</html>
